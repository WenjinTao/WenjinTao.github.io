---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  href?: string;
  icon?: string;
}

const { title, description, tags = [], href = '/projects', icon = '&#9881;' } = Astro.props;
---

<a href={href} class="glass-card-hover p-6 block group">
  <div class="text-3xl mb-4" set:html={icon} />
  <h3 class="text-lg font-semibold text-white group-hover:text-cyan-400 transition-colors mb-2">{title}</h3>
  <p class="text-sm text-gray-400 mb-4 line-clamp-2">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map(tag => (
        <span class="text-xs px-2 py-1 rounded-full bg-cyan-500/10 text-cyan-400 border border-cyan-400/20">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
