---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center mb-12">
  <h2 class="text-3xl md:text-4xl font-bold gradient-text mb-3">{title}</h2>
  {subtitle && <p class="text-gray-400 max-w-2xl mx-auto">{subtitle}</p>}
  <div class="glow-line max-w-xs mx-auto mt-6"></div>
</div>
