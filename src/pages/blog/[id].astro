---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | Wenjin Tao`}>
  <article class="page-top pb-24">
    <div class="section-container max-w-3xl">
      <a href="/blog" class="text-cyan-400 text-sm hover:underline mb-6 inline-block">&larr; Back to Blog</a>

      <p class="text-sm text-cyan-400 font-mono mb-3">{post.data.date}</p>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">{post.data.title}</h1>
      <p class="text-lg text-gray-400 mb-6">{post.data.description}</p>

      <div class="flex flex-wrap gap-2 mb-8">
        {post.data.tags.map((tag: string) => (
          <span class="text-xs px-2 py-1 rounded-full bg-cyan-500/10 text-cyan-400 border border-cyan-400/20">
            {tag}
          </span>
        ))}
      </div>

      <div class="glow-line mb-8"></div>

      <div class="prose prose-invert prose-cyan max-w-none
        prose-headings:text-white prose-headings:font-bold
        prose-p:text-gray-300
        prose-li:text-gray-300
        prose-strong:text-white
        prose-a:text-cyan-400 prose-a:no-underline hover:prose-a:underline">
        <Content />
      </div>
    </div>
  </article>
</Layout>
