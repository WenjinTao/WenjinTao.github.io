---
import Layout from '../../layouts/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Blog | Wenjin Tao">
  <section class="page-top pb-24">
    <div class="section-container max-w-4xl">
      <SectionHeading
        title="Thoughts & Threads"
        subtitle="Reflections on product management, AI strategy, and the future of manufacturing."
      />

      <div class="space-y-6">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="glass-card-hover p-6 block group">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="text-lg font-semibold text-white group-hover:text-cyan-400 transition-colors mb-2">
                  {post.data.title}
                </h3>
                <p class="text-sm text-gray-400">{post.data.description}</p>
              </div>
              <span class="text-xs text-cyan-400 font-mono whitespace-nowrap">{post.data.date}</span>
            </div>
            <div class="flex flex-wrap gap-2 mt-4">
              {post.data.tags.map((tag: string) => (
                <span class="text-xs px-2 py-1 rounded-full bg-cyan-500/10 text-cyan-400 border border-cyan-400/20">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
