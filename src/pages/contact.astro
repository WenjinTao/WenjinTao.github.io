---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout title="Contact | Wenjin Tao">
  <section class="page-top pb-24">
    <div class="section-container max-w-2xl">
      <SectionHeading title="Get in Touch" />

      <div class="flex justify-center">
        <a
          href="https://www.linkedin.com/in/wenjin-tao/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Connect on LinkedIn"
          class="grid h-16 w-16 place-items-center rounded-2xl border border-cyan-300/20 bg-cyan-300/[0.05] text-cyan-100/80 transition-all duration-300 hover:border-cyan-200/60 hover:text-cyan-100 hover:shadow-[0_0_28px_rgba(34,211,238,0.3)]"
        >
          <svg class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
