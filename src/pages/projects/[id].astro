---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={`${project.data.title} | Wenjin Tao`}>
  <article class="page-top pb-24">
    <div class="section-container max-w-3xl">
      <a href="/projects" class="text-cyan-400 text-sm hover:underline mb-6 inline-block">&larr; Back to Projects</a>

      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">{project.data.title}</h1>
      <p class="text-lg text-gray-400 mb-6">{project.data.description}</p>

      <div class="flex flex-wrap gap-1.5 mb-8">
        {project.data.tags.map((tag: string) => (
          <span class="rounded-full border border-cyan-300/15 bg-cyan-300/[0.05] px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.14em] text-cyan-100/70">
            {tag}
          </span>
        ))}
      </div>

      <div class="glow-line mb-8"></div>

      <div class="prose prose-invert prose-cyan max-w-none
        prose-headings:text-white prose-headings:font-bold
        prose-p:text-gray-300
        prose-li:text-gray-300
        prose-strong:text-white
        prose-a:text-cyan-400 prose-a:no-underline hover:prose-a:underline">
        <Content />
      </div>
    </div>
  </article>
</Layout>
