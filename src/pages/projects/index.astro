---
import Layout from '../../layouts/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Layout title="Projects | Wenjin Tao">
  <section class="page-top pb-24">
    <div class="section-container">
      <SectionHeading
        title="Projects"
        subtitle="A collection of projects spanning robotics, computer vision, AI, and manufacturing systems."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map(project => (
          <div class="glass-card relative flex flex-col overflow-hidden p-6">
            <h3 class="text-lg font-semibold text-white mb-2">
              {project.data.title}
            </h3>
            <p class="text-sm text-gray-400 mb-4 flex-1">{project.data.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {project.data.tags.map((tag: string) => (
                <span class="rounded-full border border-cyan-300/15 bg-cyan-300/[0.05] px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.14em] text-cyan-100/70">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
